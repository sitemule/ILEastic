# Copy this file to .env and fill in your values.
# .env is git-ignored.

# SSH hostname or alias of your IBM i (must be in ~/.ssh/config or known_hosts)
I_HOST=my-ibmi

# IFS path where the project is deployed on the IBM i
DELPOY_PATH=/prj/ILEastic

# Set to true when opening the project directly from the IBM i IFS via a
# network share (SMB/NFS). rsync is skipped automatically for mounted shares
# (detected via df), but you can force it here if auto-detection is wrong.
# SKIP_RSYNC=true
